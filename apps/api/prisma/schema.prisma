generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Language {
  EN
  VI
}

enum ContentStatus {
  DRAFT
  PUBLISHED
}

enum PostStatus {
  DRAFT
  PUBLISHED
  PRIVATE
  UNLISTED
}

enum SocialPlatform {
  GITHUB
  LINKEDIN
  TWITTER
  BLUESKY
  STACKOVERFLOW
  DEV_TO
  HASHNODE
  WEBSITE
  OTHER
}

enum Availability {
  OPEN_TO_WORK
  EMPLOYED
  FREELANCING
  NOT_AVAILABLE
}

enum SkillCategory {
  TECHNICAL
  TOOLS
  ADDITIONAL
}

enum ProjectCategory {
  LANDING_PAGE
  CMS
  ERP
  E_COMMERCE
  DASHBOARD
  API
  MOBILE_APP
  LIBRARY
  CLI_TOOL
  OTHER
}

enum ProjectType {
  PERSONAL
  TEAM
  COMPANY
  OPEN_SOURCE
  FREELANCE
}

enum ProjectSize {
  SMALL
  MEDIUM
  LARGE
  ENTERPRISE
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  FREELANCE
  INTERNSHIP
  SELF_EMPLOYED
}

enum LocationType {
  REMOTE
  HYBRID
  ONSITE
}

enum SyncStatus {
  SYNCED
  PENDING
  FAILED
}

enum ContactPurpose {
  GENERAL
  JOB_OPPORTUNITY
  FREELANCE
  COLLABORATION
  BUG_REPORT
  OTHER
}

enum ContactMessageStatus {
  UNREAD
  READ
  REPLIED
  ARCHIVED
}

enum Role {
  ADMIN
  USER
}

model User {
  id                     String    @id @db.Uuid
  email                  String    @unique
  password               String?
  name                   String
  role                   Role      @default(USER)
  lastLoginAt            DateTime?
  refreshToken           String?
  refreshTokenExpiresAt  DateTime?
  passwordResetToken     String?
  passwordResetExpiresAt DateTime?
  googleId               String?   @unique
  failedLoginAttempts    Int       @default(0)
  lockedUntil            DateTime?
  tokenVersion           Int       @default(0)
  deletedAt              DateTime?
  inviteToken            String?
  inviteTokenExpiresAt   DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  // Profile relations
  profile         Profile?  @relation("ProfileUser")
  profilesCreated Profile[] @relation("ProfileCreatedBy")
  profilesUpdated Profile[] @relation("ProfileUpdatedBy")

  // Tag relations
  tagsCreated    Tag[] @relation("TagCreatedBy")
  tagsUpdated    Tag[] @relation("TagUpdatedBy")
  tagsDeleted    Tag[] @relation("TagDeletedBy")

  // Category relations
  categoriesCreated Category[] @relation("CategoryCreatedBy")
  categoriesUpdated Category[] @relation("CategoryUpdatedBy")
  categoriesDeleted Category[] @relation("CategoryDeletedBy")

  // Skill relations
  skillsCreated Skill[] @relation("SkillCreatedBy")
  skillsUpdated Skill[] @relation("SkillUpdatedBy")
  skillsDeleted Skill[] @relation("SkillDeletedBy")

  // Media relations
  mediaCreated Media[] @relation("MediaCreatedBy")
  mediaUpdated Media[] @relation("MediaUpdatedBy")
  mediaDeleted Media[] @relation("MediaDeletedBy")

  // Experience relations
  experiencesCreated Experience[] @relation("ExperienceCreatedBy")
  experiencesUpdated Experience[] @relation("ExperienceUpdatedBy")
  experiencesDeleted Experience[] @relation("ExperienceDeletedBy")

  // Project relations
  projectsCreated Project[] @relation("ProjectCreatedBy")
  projectsUpdated Project[] @relation("ProjectUpdatedBy")
  projectsDeleted Project[] @relation("ProjectDeletedBy")

  // BlogPost relations
  postsAuthored  BlogPost[] @relation("PostAuthor")
  postsCreated   BlogPost[] @relation("PostCreatedBy")
  postsUpdated   BlogPost[] @relation("PostUpdatedBy")
  postsDeleted   BlogPost[] @relation("PostDeletedBy")

  @@map("users")
}

model Tag {
  id          String    @id @db.Uuid
  name        String
  slug        String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdById String    @db.Uuid
  updatedById String    @db.Uuid
  deletedAt   DateTime?
  deletedById String?   @db.Uuid

  createdBy   User      @relation("TagCreatedBy", fields: [createdById], references: [id])
  updatedBy   User      @relation("TagUpdatedBy", fields: [updatedById], references: [id])
  deletedBy   User?     @relation("TagDeletedBy", fields: [deletedById], references: [id])
  posts       PostTag[]

  @@index([name])
  @@index([slug])
  @@map("tags")
}

model Category {
  id           String    @id @db.Uuid
  name         String
  slug         String
  description  String?
  displayOrder Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  createdById  String    @db.Uuid
  updatedById  String    @db.Uuid
  deletedAt    DateTime?
  deletedById  String?   @db.Uuid

  createdBy User           @relation("CategoryCreatedBy", fields: [createdById], references: [id])
  updatedBy User           @relation("CategoryUpdatedBy", fields: [updatedById], references: [id])
  deletedBy User?          @relation("CategoryDeletedBy", fields: [deletedById], references: [id])
  posts     PostCategory[]

  @@index([name])
  @@index([slug])
  @@map("categories")
}

model Skill {
  id                String        @id @db.Uuid
  name              String
  slug              String
  description       String?
  category          SkillCategory
  isLibrary         Boolean       @default(false)
  parentSkillId     String?       @db.Uuid
  yearsOfExperience Int?
  iconId            String?       @db.Uuid
  proficiencyNote   String?
  isFeatured        Boolean       @default(false)
  displayOrder      Int           @default(0)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  createdById       String        @db.Uuid
  updatedById       String        @db.Uuid
  deletedAt         DateTime?
  deletedById       String?       @db.Uuid

  parentSkill  Skill?           @relation("SkillParent", fields: [parentSkillId], references: [id])
  childSkills  Skill[]          @relation("SkillParent")
  icon         Media?           @relation("SkillIcon", fields: [iconId], references: [id])
  createdBy    User             @relation("SkillCreatedBy", fields: [createdById], references: [id])
  updatedBy    User             @relation("SkillUpdatedBy", fields: [updatedById], references: [id])
  deletedBy    User?            @relation("SkillDeletedBy", fields: [deletedById], references: [id])
  experiences  ExperienceSkill[]
  projects     ProjectSkill[]

  @@map("skills")
}

model Media {
  id               String    @id @db.Uuid
  originalFilename String
  mimeType         String
  publicId         String    @unique
  url              String
  format           String
  bytes            Int
  width            Int?
  height           Int?
  altText          String?
  caption          String?
  folder           String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  createdById      String    @db.Uuid
  updatedById      String    @db.Uuid
  deletedAt        DateTime?
  deletedById      String?   @db.Uuid

  createdBy User  @relation("MediaCreatedBy", fields: [createdById], references: [id])
  updatedBy User  @relation("MediaUpdatedBy", fields: [updatedById], references: [id])
  deletedBy User? @relation("MediaDeletedBy", fields: [deletedById], references: [id])

  // Profile relations
  profileAvatars  Profile[] @relation("ProfileAvatar")
  profileOgImages Profile[] @relation("ProfileOgImage")

  // Experience relations
  experienceLogos Experience[] @relation("ExperienceCompanyLogo")

  // Project relations
  projectThumbnails ProjectImage[] @relation("ProjectImageMedia")
  projectCovers     Project[]      @relation("ProjectThumbnail")

  // Skill relations
  skillIcons  Skill[] @relation("SkillIcon")

  // BlogPost relations
  postFeaturedImages BlogPost[] @relation("PostFeaturedImage")

  @@index([mimeType])
  @@index([deletedAt])
  @@index([createdById])
  @@index([createdAt])
  @@map("media")
}

model ContactMessage {
  id             String               @id @db.Uuid
  name           String               @db.VarChar(200)
  email          String               @db.VarChar(320)
  purpose        ContactPurpose       @default(GENERAL)
  subject        String?              @db.VarChar(500)
  message        String
  status         ContactMessageStatus @default(UNREAD)
  isSpam         Boolean              @default(false)
  ipAddress      String?              @db.VarChar(64)
  userAgent      String?              @db.VarChar(512)
  locale         String               @default("en") @db.VarChar(5)
  consentGivenAt DateTime
  createdAt      DateTime             @default(now())
  readAt         DateTime?
  repliedAt      DateTime?
  archivedAt     DateTime?
  expiresAt      DateTime
  deletedAt      DateTime?

  @@index([status, deletedAt])
  @@index([createdAt])
  @@index([expiresAt])
  @@index([email])
  @@map("contact_messages")
}

model Profile {
  // Identity
  id     String @id @db.Uuid
  userId String @unique @db.Uuid

  // Translatable
  fullName  Json
  title     Json
  bioShort  Json
  bioLong   Json?

  // Work
  yearsOfExperience Int
  availability      Availability @default(EMPLOYED)
  openTo            Json         @default("[]")

  // Contact
  email                    String       @db.VarChar(320)
  phone                    String?      @db.VarChar(20)
  preferredContactPlatform SocialPlatform @default(LINKEDIN)
  preferredContactValue    String       @db.VarChar(500)

  // Location
  locationCountry     String  @db.VarChar(100)
  locationCity        String  @db.VarChar(100)
  locationPostalCode  String? @db.VarChar(20)
  locationAddress1    String? @db.VarChar(200)
  locationAddress2    String? @db.VarChar(200)

  // Social/Resume
  socialLinks Json @default("[]")
  resumeUrls  Json @default("{}")

  // Certifications
  certifications Json @default("[]")

  // SEO
  metaTitle       String? @db.VarChar(70)
  metaDescription String? @db.VarChar(160)
  ogImageId       String? @db.Uuid

  // Misc
  timezone     String? @db.VarChar(50)
  canonicalUrl String? @db.VarChar(500)

  // Media
  avatarId String? @db.Uuid

  // Audit
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String   @db.Uuid
  updatedById String   @db.Uuid

  // Relations
  user      User   @relation("ProfileUser", fields: [userId], references: [id])
  avatar    Media? @relation("ProfileAvatar", fields: [avatarId], references: [id])
  ogImage   Media? @relation("ProfileOgImage", fields: [ogImageId], references: [id])
  createdBy User   @relation("ProfileCreatedBy", fields: [createdById], references: [id])
  updatedBy User   @relation("ProfileUpdatedBy", fields: [updatedById], references: [id])

  @@index([userId])
  @@map("profiles")
}

model Experience {
  // Identity
  id   String @id @db.Uuid
  slug String @db.VarChar(200)

  // Company
  companyName    String  @db.VarChar(200)
  companyUrl     String? @db.VarChar(500)
  companyLogoId  String? @db.Uuid

  // Translatable (JSONB)
  position         Json  @db.JsonB
  description      Json? @db.JsonB
  responsibilities Json  @default("{}") @db.JsonB
  highlights       Json  @default("{}") @db.JsonB
  teamRole         Json? @db.JsonB

  // Links (non-translatable JSON array of { label, url })
  links Json @default("[]") @db.JsonB

  // Employment
  employmentType EmploymentType @default(FULL_TIME)
  locationType   LocationType   @default(ONSITE)

  // Location
  locationCountry    String  @db.VarChar(100)
  locationCity       String? @db.VarChar(100)
  locationPostalCode String? @db.VarChar(20)
  locationAddress1   String? @db.VarChar(300)
  locationAddress2   String? @db.VarChar(300)

  // Client context
  clientName  String? @db.VarChar(200)
  domain      String? @db.VarChar(100)
  teamSizeMin Int?
  teamSizeMax Int?

  // Dates
  startDate DateTime
  endDate   DateTime?

  // Display
  displayOrder Int @default(0)

  // Audit
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdById String    @db.Uuid
  updatedById String    @db.Uuid
  deletedAt   DateTime?
  deletedById String?   @db.Uuid

  // Relations
  companyLogo Media?            @relation("ExperienceCompanyLogo", fields: [companyLogoId], references: [id], onDelete: SetNull)
  createdBy   User              @relation("ExperienceCreatedBy", fields: [createdById], references: [id])
  updatedBy   User              @relation("ExperienceUpdatedBy", fields: [updatedById], references: [id])
  deletedBy   User?             @relation("ExperienceDeletedBy", fields: [deletedById], references: [id])
  skills      ExperienceSkill[]

  @@index([startDate])
  @@index([deletedAt])
  @@index([displayOrder])
  @@index([slug])
  @@map("experiences")
}

model ExperienceSkill {
  experienceId String @db.Uuid
  skillId      String @db.Uuid

  experience Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  skill      Skill      @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([experienceId, skillId])
  @@map("experience_skills")
}

model Project {
  id           String        @id @db.Uuid
  slug         String        @db.VarChar(200)

  // Not translatable
  title        String        @db.VarChar(200)

  // Translatable (JSONB)
  oneLiner     Json          @db.JsonB
  description  Json          @db.JsonB
  motivation   Json          @db.JsonB
  role         Json          @db.JsonB

  // Dates
  startDate    DateTime      @db.Date
  endDate      DateTime?     @db.Date

  // Status & Display
  status       ContentStatus @default(DRAFT)
  featured     Boolean       @default(false)
  displayOrder Int           @default(0)

  // Links
  sourceUrl    String?       @db.VarChar(500)
  projectUrl   String?       @db.VarChar(500)

  // Media
  thumbnailId  String?       @db.Uuid

  // Audit
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  createdById  String        @db.Uuid
  updatedById  String        @db.Uuid
  deletedAt    DateTime?
  deletedById  String?       @db.Uuid

  // Relations
  thumbnail    Media?              @relation("ProjectThumbnail", fields: [thumbnailId], references: [id])
  createdBy    User                @relation("ProjectCreatedBy", fields: [createdById], references: [id])
  updatedBy    User                @relation("ProjectUpdatedBy", fields: [updatedById], references: [id])
  deletedBy    User?               @relation("ProjectDeletedBy", fields: [deletedById], references: [id])
  highlights   TechnicalHighlight[]
  images       ProjectImage[]
  skills       ProjectSkill[]

  @@index([status, deletedAt])
  @@index([featured, status, deletedAt])
  @@index([displayOrder])
  @@index([slug])
  @@map("projects")
}

model TechnicalHighlight {
  id           String  @id @db.Uuid
  projectId    String  @db.Uuid

  // CAO structure — all translatable
  challenge    Json    @db.JsonB
  approach     Json    @db.JsonB
  outcome      Json    @db.JsonB

  codeUrl      String? @db.VarChar(500)
  displayOrder Int     @default(0)

  project      Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, displayOrder])
  @@map("technical_highlights")
}

model ProjectImage {
  id           String  @id @db.Uuid
  projectId    String  @db.Uuid
  mediaId      String  @db.Uuid
  displayOrder Int     @default(0)

  project      Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  media        Media   @relation("ProjectImageMedia", fields: [mediaId], references: [id])

  @@unique([projectId, mediaId])
  @@index([projectId, displayOrder])
  @@map("project_images")
}

model ProjectSkill {
  projectId String @db.Uuid
  skillId   String @db.Uuid

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  skill     Skill   @relation(fields: [skillId], references: [id])

  @@id([projectId, skillId])
  @@map("project_skills")
}

model BlogPost {
  id              String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug            String     @db.VarChar(200)
  language        Language   @default(EN)

  // Content
  title           String     @db.VarChar(300)
  excerpt         String?    @db.VarChar(500)
  content         String     @db.Text
  readTimeMinutes Int?

  // Status & Display
  status          PostStatus @default(DRAFT)
  featured        Boolean    @default(false)
  publishedAt     DateTime?

  // SEO
  metaTitle       String?    @db.VarChar(200)
  metaDescription String?    @db.VarChar(500)

  // Relations
  authorId        String     @db.Uuid
  featuredImageId String?    @db.Uuid

  // Audit
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  createdById     String     @db.Uuid
  updatedById     String     @db.Uuid
  deletedAt       DateTime?
  deletedById     String?    @db.Uuid

  // Relation definitions
  author        User           @relation("PostAuthor", fields: [authorId], references: [id])
  featuredImage Media?         @relation("PostFeaturedImage", fields: [featuredImageId], references: [id])
  createdBy     User           @relation("PostCreatedBy", fields: [createdById], references: [id])
  updatedBy     User           @relation("PostUpdatedBy", fields: [updatedById], references: [id])
  deletedBy     User?          @relation("PostDeletedBy", fields: [deletedById], references: [id])
  categories    PostCategory[]
  tags          PostTag[]

  @@index([status, deletedAt])
  @@index([featured, status, deletedAt])
  @@index([language, status, deletedAt])
  @@index([publishedAt])
  @@index([slug])
  @@map("blog_posts")
}

model PostCategory {
  postId     String @db.Uuid
  categoryId String @db.Uuid

  post     BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])

  @@id([postId, categoryId])
  @@map("post_categories")
}

model PostTag {
  postId String @db.Uuid
  tagId  String @db.Uuid

  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  Tag      @relation(fields: [tagId], references: [id])

  @@id([postId, tagId])
  @@map("post_tags")
}
