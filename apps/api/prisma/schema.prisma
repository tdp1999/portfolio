generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Language {
  EN
  VI
}

enum ContentStatus {
  DRAFT
  PUBLISHED
}

enum SocialPlatform {
  GITHUB
  LINKEDIN
  TWITTER
  BLUESKY
  STACKOVERFLOW
  DEV_TO
  HASHNODE
  WEBSITE
  OTHER
}

enum Availability {
  OPEN_TO_WORK
  EMPLOYED
  FREELANCING
  NOT_AVAILABLE
}

enum SkillCategory {
  TECHNICAL
  TOOLS
  ADDITIONAL
}

enum ProjectCategory {
  LANDING_PAGE
  CMS
  ERP
  E_COMMERCE
  DASHBOARD
  API
  MOBILE_APP
  LIBRARY
  CLI_TOOL
  OTHER
}

enum ProjectType {
  PERSONAL
  TEAM
  COMPANY
  OPEN_SOURCE
  FREELANCE
}

enum ProjectSize {
  SMALL
  MEDIUM
  LARGE
  ENTERPRISE
}

enum SyncStatus {
  SYNCED
  PENDING
  FAILED
}

enum ContactPurpose {
  GENERAL
  JOB_OPPORTUNITY
  FREELANCE
  COLLABORATION
  BUG_REPORT
  OTHER
}

enum ContactMessageStatus {
  UNREAD
  READ
  REPLIED
  ARCHIVED
}

enum Role {
  ADMIN
  USER
}

model User {
  id                     String    @id @db.Uuid
  email                  String    @unique
  password               String?
  name                   String
  role                   Role      @default(USER)
  lastLoginAt            DateTime?
  refreshToken           String?
  refreshTokenExpiresAt  DateTime?
  passwordResetToken     String?
  passwordResetExpiresAt DateTime?
  googleId               String?   @unique
  failedLoginAttempts    Int       @default(0)
  lockedUntil            DateTime?
  tokenVersion           Int       @default(0)
  deletedAt              DateTime?
  inviteToken            String?
  inviteTokenExpiresAt   DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  // Profile relations
  profile         Profile?  @relation("ProfileUser")
  profilesCreated Profile[] @relation("ProfileCreatedBy")
  profilesUpdated Profile[] @relation("ProfileUpdatedBy")

  // Tag relations
  tagsCreated    Tag[] @relation("TagCreatedBy")
  tagsUpdated    Tag[] @relation("TagUpdatedBy")
  tagsDeleted    Tag[] @relation("TagDeletedBy")

  // Category relations
  categoriesCreated Category[] @relation("CategoryCreatedBy")
  categoriesUpdated Category[] @relation("CategoryUpdatedBy")
  categoriesDeleted Category[] @relation("CategoryDeletedBy")

  // Skill relations
  skillsCreated Skill[] @relation("SkillCreatedBy")
  skillsUpdated Skill[] @relation("SkillUpdatedBy")
  skillsDeleted Skill[] @relation("SkillDeletedBy")

  // Media relations
  mediaCreated Media[] @relation("MediaCreatedBy")
  mediaUpdated Media[] @relation("MediaUpdatedBy")
  mediaDeleted Media[] @relation("MediaDeletedBy")

  @@map("users")
}

model Tag {
  id          String    @id @db.Uuid
  name        String    @unique
  slug        String    @unique
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdById String    @db.Uuid
  updatedById String    @db.Uuid
  deletedAt   DateTime?
  deletedById String?   @db.Uuid

  createdBy   User      @relation("TagCreatedBy", fields: [createdById], references: [id])
  updatedBy   User      @relation("TagUpdatedBy", fields: [updatedById], references: [id])
  deletedBy   User?     @relation("TagDeletedBy", fields: [deletedById], references: [id])

  @@map("tags")
}

model Category {
  id           String    @id @db.Uuid
  name         String    @unique
  slug         String    @unique
  description  String?
  displayOrder Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  createdById  String    @db.Uuid
  updatedById  String    @db.Uuid
  deletedAt    DateTime?
  deletedById  String?   @db.Uuid

  createdBy User  @relation("CategoryCreatedBy", fields: [createdById], references: [id])
  updatedBy User  @relation("CategoryUpdatedBy", fields: [updatedById], references: [id])
  deletedBy User? @relation("CategoryDeletedBy", fields: [deletedById], references: [id])

  @@map("categories")
}

model Skill {
  id                String        @id @db.Uuid
  name              String
  slug              String
  description       String?
  category          SkillCategory
  isLibrary         Boolean       @default(false)
  parentSkillId     String?       @db.Uuid
  yearsOfExperience Int?
  iconUrl           String?
  proficiencyNote   String?
  isFeatured        Boolean       @default(false)
  displayOrder      Int           @default(0)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  createdById       String        @db.Uuid
  updatedById       String        @db.Uuid
  deletedAt         DateTime?
  deletedById       String?       @db.Uuid

  parentSkill Skill?  @relation("SkillParent", fields: [parentSkillId], references: [id])
  childSkills Skill[] @relation("SkillParent")
  createdBy   User    @relation("SkillCreatedBy", fields: [createdById], references: [id])
  updatedBy   User    @relation("SkillUpdatedBy", fields: [updatedById], references: [id])
  deletedBy   User?   @relation("SkillDeletedBy", fields: [deletedById], references: [id])

  @@map("skills")
}

model Media {
  id               String    @id @db.Uuid
  originalFilename String
  mimeType         String
  publicId         String    @unique
  url              String
  format           String
  bytes            Int
  width            Int?
  height           Int?
  altText          String?
  caption          String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  createdById      String    @db.Uuid
  updatedById      String    @db.Uuid
  deletedAt        DateTime?
  deletedById      String?   @db.Uuid

  createdBy User  @relation("MediaCreatedBy", fields: [createdById], references: [id])
  updatedBy User  @relation("MediaUpdatedBy", fields: [updatedById], references: [id])
  deletedBy User? @relation("MediaDeletedBy", fields: [deletedById], references: [id])

  // Profile relations
  profileAvatars  Profile[] @relation("ProfileAvatar")
  profileOgImages Profile[] @relation("ProfileOgImage")

  @@index([mimeType])
  @@index([deletedAt])
  @@index([createdById])
  @@index([createdAt])
  @@map("media")
}

model ContactMessage {
  id             String               @id @db.Uuid
  name           String               @db.VarChar(200)
  email          String               @db.VarChar(320)
  purpose        ContactPurpose       @default(GENERAL)
  subject        String?              @db.VarChar(500)
  message        String
  status         ContactMessageStatus @default(UNREAD)
  isSpam         Boolean              @default(false)
  ipAddress      String?              @db.VarChar(64)
  userAgent      String?              @db.VarChar(512)
  locale         String               @default("en") @db.VarChar(5)
  consentGivenAt DateTime
  createdAt      DateTime             @default(now())
  readAt         DateTime?
  repliedAt      DateTime?
  archivedAt     DateTime?
  expiresAt      DateTime
  deletedAt      DateTime?

  @@index([status, deletedAt])
  @@index([createdAt])
  @@index([expiresAt])
  @@index([email])
  @@map("contact_messages")
}

model Profile {
  // Identity
  id     String @id @db.Uuid
  userId String @unique @db.Uuid

  // Translatable
  fullName  Json
  title     Json
  bioShort  Json
  bioLong   Json?

  // Work
  yearsOfExperience Int
  availability      Availability @default(EMPLOYED)
  openTo            Json         @default("[]")

  // Contact
  email                    String       @db.VarChar(320)
  phone                    String?      @db.VarChar(20)
  preferredContactPlatform SocialPlatform @default(LINKEDIN)
  preferredContactValue    String       @db.VarChar(500)

  // Location
  locationCountry     String  @db.VarChar(100)
  locationCity        String  @db.VarChar(100)
  locationPostalCode  String? @db.VarChar(20)
  locationAddress1    String? @db.VarChar(200)
  locationAddress2    String? @db.VarChar(200)

  // Social/Resume
  socialLinks Json @default("[]")
  resumeUrls  Json @default("{}")

  // Certifications
  certifications Json @default("[]")

  // SEO
  metaTitle       String? @db.VarChar(70)
  metaDescription String? @db.VarChar(160)
  ogImageId       String? @db.Uuid

  // Misc
  timezone     String? @db.VarChar(50)
  canonicalUrl String? @db.VarChar(500)

  // Media
  avatarId String? @db.Uuid

  // Audit
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String   @db.Uuid
  updatedById String   @db.Uuid

  // Relations
  user      User   @relation("ProfileUser", fields: [userId], references: [id])
  avatar    Media? @relation("ProfileAvatar", fields: [avatarId], references: [id])
  ogImage   Media? @relation("ProfileOgImage", fields: [ogImageId], references: [id])
  createdBy User   @relation("ProfileCreatedBy", fields: [createdById], references: [id])
  updatedBy User   @relation("ProfileUpdatedBy", fields: [updatedById], references: [id])

  @@index([userId])
  @@map("profiles")
}
