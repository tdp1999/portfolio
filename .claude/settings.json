{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "if": "Edit(*.html)",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/design-bank-nudge.sh\"",
            "timeout": 5
          },
          {
            "type": "command",
            "if": "Write(*.html)",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/design-bank-nudge.sh\"",
            "timeout": 5
          },
          {
            "type": "command",
            "if": "Edit(*.scss)",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/design-bank-nudge.sh\"",
            "timeout": 5
          },
          {
            "type": "command",
            "if": "Write(*.scss)",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/design-bank-nudge.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "test -f scripts/scale-audit.js && node scripts/scale-audit.js || true",
            "timeout": 10,
            "statusMessage": "Checking 4px grid compliance..."
          }
        ]
      }
    ]
  }
}
