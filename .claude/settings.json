{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "test -f scripts/scale-audit.js && node scripts/scale-audit.js || true",
            "timeout": 10,
            "statusMessage": "Checking 4px grid compliance..."
          }
        ]
      }
    ]
  }
}
