# ===========================================
# API Service (NestJS on Railway)
# ===========================================

# Database — Railway Postgres (internal URL in production)
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/portfolio"

# Auth (JWT)
JWT_SECRET="change-me"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_SECRET="change-me-too"
JWT_REFRESH_EXPIRY="30d"

# CORS — comma-separated allowed origins
CORS_ORIGINS="http://localhost:4200,http://localhost:4300"

# Frontend URL — used in password reset emails, redirects
FRONTEND_URL="http://localhost:4300"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3000/api/auth/google/callback"

# Email (Resend)
RESEND_API_KEY="re_xxxxxxxxxxxx"
EMAIL_FROM="noreply@example.com"

# Cloudinary — file/image storage
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
CLOUDINARY_FOLDER_PREFIX="dev"  # leave empty or remove in production

# Contact Message — admin notification on new submissions
ADMIN_NOTIFICATION_EMAIL="admin@example.com"
CONSOLE_URL="http://localhost:4300"

# Admin Seed — creates initial admin user (idempotent)
ADMIN_EMAIL="admin@example.com"
ADMIN_NAME="Admin"
ADMIN_PASSWORD="ChangeMe1!"

# ===========================================
# Console SPA (Angular on Cloudflare Pages)
# ===========================================
# API URL is set at build time in:
#   apps/console/src/environments/environment.ts
# No runtime env vars needed — CF Pages bakes at build.
