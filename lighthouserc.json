{
  "$schema": "https://raw.githubusercontent.com/GoogleChrome/lighthouse-ci/main/docs/configuration.md",
  "ci": {
    "collect": {
      "url": [
        "http://localhost:4000/",
        "http://localhost:4000/projects",
        "http://localhost:4000/uses",
        "http://localhost:4000/colophon"
      ],
      "numberOfRuns": 1,
      "startServerCommand": "node dist/apps/landing/server/server.mjs",
      "startServerReadyPattern": "Node Express server listening",
      "startServerReadyTimeout": 30000,
      "settings": {
        "preset": "desktop",
        "chromeFlags": "--no-sandbox --disable-gpu"
      }
    },
    "assert": {
      "assertions": {
        "categories:accessibility": ["error", { "minScore": 0.8 }],
        "categories:best-practices": ["error", { "minScore": 0.8 }],
        "categories:seo": ["error", { "minScore": 0.8 }],
        "categories:performance": ["warn", { "minScore": 0.8 }]
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": ".lighthouseci"
    }
  }
}
